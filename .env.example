# Copy to .env for local dev. Local dev uses embedded-postgres (see `npm run db`).
# App runtime + migrations use the NON-superuser app_user so Postgres RLS is enforced.
# Seeding uses the superuser URL to bypass RLS and insert across orgs.
# Hosted envs (Vercel): these are set PER-ENVIRONMENT (Preview / Production) via the Vercel
# dashboard/CLI and are never committed — this file is only the documented var contract.
DATABASE_URL="postgresql://app_user:app_user@localhost:5432/shift_ledger?schema=public"
SUPERUSER_DATABASE_URL="postgresql://postgres:postgres@localhost:5432/shift_ledger?schema=public"

# Production: point DATABASE_URL at Neon EU (a non-superuser role). Never use a
# superuser/BYPASSRLS role for the app runtime connection.

SENTRY_DSN=""
NEXT_PUBLIC_SENTRY_DSN=""
LOG_LEVEL="info"
