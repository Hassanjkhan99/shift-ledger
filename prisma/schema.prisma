// Shift Ledger — Milestone 1 foundation schema.
// Conventions (CTO decisions): UUID v7 PKs (DB-generated, PG18 native uuidv7()),
// organization_id on every tenant-scoped table, timestamptz, soft-delete via deleted_at
// (except append-only tables). RLS + FORCE, policies, and the activity_log append-only
// trigger are applied via raw SQL in a follow-up migration (Prisma cannot express them).

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ---- Canonical enums (per CTO decisions D1/D2/F8) -------------------------------
// Only the enums used by Milestone-1 tables are defined here. The task/exception/
// corrective-action status enums land with their tables in later milestones; their
// canonical values are already locked in D1/D2.

enum OrgRole {
  Owner
  OrgAdmin
  PropertyManager
  KitchenManager
  ShiftLeader
  Staff
  Auditor
  ExternalInspector

  @@map("org_role")
}

enum InvitationStatus {
  pending
  accepted
  revoked
  expired

  @@map("invitation_status")
}

// ---- Occurrence-domain enums (#8; §8.0 / §8.11-§8.13) ---------------------------

enum CheckType {
  temperature
  cleaning
  allergen
  opening
  closing
  generic

  @@map("check_type")
}

enum EvidenceType {
  note
  photo
  temperature
  checkbox
  initials
  signature
  file

  @@map("evidence_type")
}

enum RecurrenceFreq {
  daily
  weekly
  monthly

  @@map("recurrence_freq")
}

// Canonical per D1/F8 (§7.1). The §9.3 prose table's `scheduled` is drift — `pending` is correct.
enum OccurrenceStatus {
  pending
  due
  overdue
  completed
  completed_late
  failed
  skipped
  cancelled

  @@map("occurrence_status")
}

enum ActivitySubjectType {
  organization
  property
  outlet
  membership
  invitation
  user
  // Full §8.20 subject set. Added ahead of their tables so transition() is generic across
  // every entity; the corresponding domain tables land in later milestones (#8/#9/#10/etc.).
  taskTemplate     @map("task_template")
  scheduledTask    @map("scheduled_task")
  taskOccurrence   @map("task_occurrence")
  taskCompletion   @map("task_completion")
  evidence         @map("evidence")
  exception        @map("exception")
  correctiveAction @map("corrective_action")
  exportJob        @map("export_job")
  notification     @map("notification")

  @@map("activity_subject_type")
}

// ---- Global identity (NOT tenant-scoped, global by design) ----------------------

model User {
  id            String    @id @default(dbgenerated("uuidv7()")) @db.Uuid
  email         String    @unique
  emailVerified Boolean   @default(false) @map("email_verified")
  name          String?
  locale        String?
  createdAt     DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)

  memberships     Membership[]
  invitationsSent Invitation[] @relation("InvitedBy")

  scheduledTasks  ScheduledTask[]  @relation("ScheduledTaskAssignee")
  taskOccurrences TaskOccurrence[] @relation("TaskOccurrenceAssignee")

  @@map("users")
}

// ---- Tenant root ----------------------------------------------------------------

model Organization {
  id              String    @id @default(dbgenerated("uuidv7()")) @db.Uuid
  name            String
  slug            String    @unique
  defaultLocale   String    @default("de") @map("default_locale")
  defaultTimezone String    @default("Europe/Berlin") @map("default_timezone")
  retentionDays   Int       @default(1095) @map("retention_days") // D5/F8: 3y default, per-org configurable
  legalHold       Boolean   @default(false) @map("legal_hold")
  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt       DateTime? @map("deleted_at") @db.Timestamptz(6)

  memberships     Membership[]
  invitations     Invitation[]
  properties      Property[]
  outlets         Outlet[]
  activityLogs    ActivityLog[]
  taskTemplates   TaskTemplate[]
  scheduledTasks  ScheduledTask[]
  taskOccurrences TaskOccurrence[]

  @@map("organizations")
}

// ---- Tenant-scoped tables (organization_id on every one) ------------------------

model Membership {
  id             String    @id @default(dbgenerated("uuidv7()")) @db.Uuid
  organizationId String    @map("organization_id") @db.Uuid
  userId         String    @map("user_id") @db.Uuid
  role           OrgRole
  propertyScope  String[]  @map("property_scope") @db.Uuid // empty = whole org; else limited to these property ids
  status         String    @default("active")
  createdAt      DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt      DateTime? @map("deleted_at") @db.Timestamptz(6)

  organization Organization @relation(fields: [organizationId], references: [id])
  user         User         @relation(fields: [userId], references: [id])

  @@unique([organizationId, userId])
  @@index([userId])
  @@index([organizationId, role])
  @@map("memberships")
}

model Invitation {
  id             String           @id @default(dbgenerated("uuidv7()")) @db.Uuid
  organizationId String           @map("organization_id") @db.Uuid
  email          String
  role           OrgRole
  propertyScope  String[]         @map("property_scope") @db.Uuid
  token          String           @unique
  status         InvitationStatus @default(pending)
  invitedById    String           @map("invited_by") @db.Uuid
  expiresAt      DateTime         @map("expires_at") @db.Timestamptz(6)
  acceptedAt     DateTime?        @map("accepted_at") @db.Timestamptz(6)
  createdAt      DateTime         @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime         @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt      DateTime?        @map("deleted_at") @db.Timestamptz(6)

  organization Organization @relation(fields: [organizationId], references: [id])
  invitedBy    User         @relation("InvitedBy", fields: [invitedById], references: [id])

  @@index([organizationId, status])
  @@index([organizationId, email])
  @@map("invitations")
}

model Property {
  id             String    @id @default(dbgenerated("uuidv7()")) @db.Uuid
  organizationId String    @map("organization_id") @db.Uuid
  name           String
  timezone       String // IANA — source of truth for occurrence wall-clock (later milestones)
  countryCode    String    @map("country_code") @db.Char(2)
  addressJson    Json?     @map("address_json")
  createdAt      DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt      DateTime? @map("deleted_at") @db.Timestamptz(6)

  organization    Organization     @relation(fields: [organizationId], references: [id])
  outlets         Outlet[]
  scheduledTasks  ScheduledTask[]
  taskOccurrences TaskOccurrence[]

  @@unique([organizationId, name])
  @@index([organizationId, deletedAt])
  @@map("properties")
}

model Outlet {
  id             String    @id @default(dbgenerated("uuidv7()")) @db.Uuid
  organizationId String    @map("organization_id") @db.Uuid
  propertyId     String    @map("property_id") @db.Uuid
  name           String
  createdAt      DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt      DateTime? @map("deleted_at") @db.Timestamptz(6)

  organization    Organization     @relation(fields: [organizationId], references: [id])
  property        Property         @relation(fields: [propertyId], references: [id])
  scheduledTasks  ScheduledTask[]
  taskOccurrences TaskOccurrence[]

  @@unique([propertyId, name])
  @@index([organizationId, propertyId, deletedAt])
  @@map("outlets")
}

// Append-only audit log. No updated_at / deleted_at. UPDATE/DELETE rejected by a
// database trigger (see the rls_immutability migration). Per-org dense seq + hash
// chain (F6) is deferred to a later milestone; seq here is a global ordering sequence.
model ActivityLog {
  id             String              @id @default(dbgenerated("uuidv7()")) @db.Uuid
  organizationId String              @map("organization_id") @db.Uuid
  seq            BigInt              @default(autoincrement())
  subjectType    ActivitySubjectType @map("subject_type")
  subjectId      String              @map("subject_id") @db.Uuid
  action         String
  actorUserId    String?             @map("actor_user_id") @db.Uuid
  actorLabel     String?             @map("actor_label")
  beforeJson     Json?               @map("before_json")
  afterJson      Json?               @map("after_json")
  reason         String?
  createdAt      DateTime            @default(now()) @map("created_at") @db.Timestamptz(6)

  organization Organization @relation(fields: [organizationId], references: [id])

  @@index([organizationId, subjectType, subjectId, seq])
  @@index([organizationId, createdAt])
  // Org-wide timeline seek (F5 keyset by seq): the per-subject index above cannot serve
  // `WHERE organization_id = ? ORDER BY seq DESC` without a sort. (#55)
  @@index([organizationId, seq])
  @@map("activity_log")
}

// ---- Occurrence domain (#8; §8.11-§8.13) ----------------------------------------
// Mutable tenant-scoped tables (soft-delete via deleted_at). RLS + FORCE + tenant_isolation
// policy applied via raw SQL in the occurrence_domain migration. NOT append-only (no reject
// trigger) — unlike activity_log / task_completions. template_library (source_library_id) is
// a later-milestone table, so source_library_id is a plain nullable UUID column with no FK yet.

model TaskTemplate {
  id               String        @id @default(dbgenerated("uuidv7()")) @db.Uuid
  organizationId   String        @map("organization_id") @db.Uuid
  sourceLibraryId  String?       @map("source_library_id") @db.Uuid
  checkType        CheckType     @map("check_type")
  title            String
  titleI18n        Json?         @map("title_i18n")
  instructions     String?
  requiredEvidence EvidenceType[] @default([]) @map("required_evidence")
  targetConfigJson Json?         @map("target_config_json")
  isActive         Boolean       @default(true) @map("is_active")
  createdAt        DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime      @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt        DateTime?     @map("deleted_at") @db.Timestamptz(6)

  organization    Organization     @relation(fields: [organizationId], references: [id])
  scheduledTasks  ScheduledTask[]
  taskOccurrences TaskOccurrence[]

  @@index([organizationId, isActive, deletedAt])
  @@index([organizationId, checkType])
  @@map("task_templates")
}

model ScheduledTask {
  id             String         @id @default(dbgenerated("uuidv7()")) @db.Uuid
  organizationId String         @map("organization_id") @db.Uuid
  propertyId     String         @map("property_id") @db.Uuid
  outletId       String         @map("outlet_id") @db.Uuid
  taskTemplateId String         @map("task_template_id") @db.Uuid
  recurrenceJson Json           @map("recurrence_json")
  recurrenceFreq RecurrenceFreq @map("recurrence_freq")
  timeOfDay      DateTime       @map("time_of_day") @db.Time(6)
  timezone       String
  assigneeRole   OrgRole?       @map("assignee_role")
  assigneeUserId String?        @map("assignee_user_id") @db.Uuid
  graceMinutes   Int            @default(15) @map("grace_minutes")
  startsOn       DateTime       @map("starts_on") @db.Date
  endsOn         DateTime?      @map("ends_on") @db.Date
  isActive       Boolean        @default(true) @map("is_active")
  createdAt      DateTime       @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime       @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt      DateTime?      @map("deleted_at") @db.Timestamptz(6)

  organization    Organization     @relation(fields: [organizationId], references: [id])
  property        Property         @relation(fields: [propertyId], references: [id])
  outlet          Outlet           @relation(fields: [outletId], references: [id])
  taskTemplate    TaskTemplate     @relation(fields: [taskTemplateId], references: [id])
  assigneeUser    User?            @relation("ScheduledTaskAssignee", fields: [assigneeUserId], references: [id])
  taskOccurrences TaskOccurrence[]

  @@index([organizationId, isActive, deletedAt])
  @@index([organizationId, outletId, isActive])
  @@index([isActive, endsOn])
  @@map("scheduled_tasks")
}

model TaskOccurrence {
  id                  String           @id @default(dbgenerated("uuidv7()")) @db.Uuid
  organizationId      String           @map("organization_id") @db.Uuid
  propertyId          String           @map("property_id") @db.Uuid
  outletId            String           @map("outlet_id") @db.Uuid
  scheduledTaskId     String           @map("scheduled_task_id") @db.Uuid
  taskTemplateId      String           @map("task_template_id") @db.Uuid
  checkType           CheckType        @map("check_type")
  occurrenceLocalDate DateTime         @map("occurrence_local_date") @db.Date
  dueAt               DateTime         @map("due_at") @db.Timestamptz(6)
  timezone            String
  status              OccurrenceStatus @default(pending)
  assigneeRole        OrgRole?         @map("assignee_role")
  assigneeUserId      String?          @map("assignee_user_id") @db.Uuid
  completedAt         DateTime?        @map("completed_at") @db.Timestamptz(6)
  createdAt           DateTime         @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt           DateTime         @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt           DateTime?        @map("deleted_at") @db.Timestamptz(6)

  organization  Organization  @relation(fields: [organizationId], references: [id])
  property      Property      @relation(fields: [propertyId], references: [id])
  outlet        Outlet        @relation(fields: [outletId], references: [id])
  scheduledTask ScheduledTask @relation(fields: [scheduledTaskId], references: [id])
  taskTemplate  TaskTemplate  @relation(fields: [taskTemplateId], references: [id])
  assigneeUser  User?         @relation("TaskOccurrenceAssignee", fields: [assigneeUserId], references: [id])

  @@unique([scheduledTaskId, occurrenceLocalDate])
  @@index([organizationId, propertyId, outletId, occurrenceLocalDate, status])
  // The overdue-sweep index is PARTIAL — (status, due_at) WHERE status IN ('pending','due') —
  // and lives only in the occurrence_domain migration (Prisma cannot express a partial index).
  // Do NOT add a full @@index([status, dueAt]) here: it would be a second, unbounded index and
  // would make `prisma migrate diff` report drift against the intentional partial index.
  @@index([organizationId, assigneeUserId, occurrenceLocalDate])
  @@index([organizationId, status, occurrenceLocalDate])
  @@map("task_occurrences")
}
