// Shift Ledger — Milestone 1 foundation schema.
// Conventions (CTO decisions): UUID v7 PKs (DB-generated, PG18 native uuidv7()),
// organization_id on every tenant-scoped table, timestamptz, soft-delete via deleted_at
// (except append-only tables). RLS + FORCE, policies, and the activity_log append-only
// trigger are applied via raw SQL in a follow-up migration (Prisma cannot express them).
//
// TENANT-QUALIFIED (COMPOSITE) FOREIGN KEYS (#94): the cross-row FKs on scheduled_tasks,
// task_occurrences, task_completions, evidence, exceptions, and corrective_actions are
// COMPOSITE — (organization_id, <ref_id>) -> parent(organization_id, id) — so a row in org A
// cannot reference a parent row belonging to another org (Postgres FK checks bypass RLS). The
// composite FKs are a DB-level integrity constraint only and live ONLY in the migration
// 20260706130000_composite_fk_tenant; the model @relation definitions below stay SINGLE-COLUMN
// (queries use the scalar _id fields), so `prisma migrate dev` drift against them is expected/known
// — same convention as the partial index / CHECK constraints that also live only in migrations.
//
// ACTOR/ASSIGNEE TENANT-MEMBERSHIP (COMPOSITE) FOREIGN KEYS (#95): the assignee/actor user columns
// (scheduled_tasks.assignee_user_id, task_completions.completed_by, exceptions.opened_by,
// corrective_actions.assignee_user_id/completed_by/verified_by) additionally carry a COMPOSITE FK
// (organization_id, <actor_col>) -> memberships(organization_id, user_id), so a named actor MUST be a
// member of the SAME org (the single-column users FK alone can't express that — users is global and FK
// checks bypass RLS). These are DB-level INTEGRITY constraints only (existence of an in-org
// membership); the ACTIVE/non-deleted membership check is enforced at the app write layer. They live
// ONLY in migration 20260706140000_actor_membership_fk; the @relation definitions below stay
// single-column to `users`, so `prisma migrate dev` drift against them is expected/known.

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ---- Canonical enums (per CTO decisions D1/D2/F8) -------------------------------
// Only the enums used by Milestone-1 tables are defined here. The task/exception/
// corrective-action status enums land with their tables in later milestones; their
// canonical values are already locked in D1/D2.

enum OrgRole {
  Owner
  OrgAdmin
  PropertyManager
  KitchenManager
  ShiftLeader
  Staff
  Auditor
  ExternalInspector

  @@map("org_role")
}

enum InvitationStatus {
  pending
  accepted
  revoked
  expired

  @@map("invitation_status")
}

// ---- Occurrence-domain enums (#8; §8.0 / §8.11-§8.13) ---------------------------

enum CheckType {
  temperature
  cleaning
  allergen
  opening
  closing
  generic

  @@map("check_type")
}

enum EvidenceType {
  note
  photo
  temperature
  checkbox
  initials
  signature
  file

  @@map("evidence_type")
}

enum RecurrenceFreq {
  daily
  weekly
  monthly

  @@map("recurrence_freq")
}

// Completion outcome (§8.14). pass/fail only — the D1 occurrence lifecycle carries the richer states.
enum CompletionResult {
  pass
  fail

  @@map("completion_result")
}

// Canonical per D1/F8 (§7.1). The §9.3 prose table's `scheduled` is drift — `pending` is correct.
enum OccurrenceStatus {
  pending
  due
  overdue
  completed
  completed_late
  failed
  skipped
  cancelled

  @@map("occurrence_status")
}

// Exception lifecycle (D2, §7.2). Terminal-happy: verified. reopened re-enters via acknowledged.
enum ExceptionStatus {
  open
  acknowledged
  in_progress
  resolved
  verified
  reopened

  @@map("exception_status")
}

// CorrectiveAction lifecycle (D2, §7.3). Terminal-happy: verified. rejected routes back to assigned.
enum CorrectiveStatus {
  open
  assigned
  done
  verified
  rejected

  @@map("corrective_status")
}

enum ActivitySubjectType {
  organization
  property
  outlet
  membership
  invitation
  user
  // Full §8.20 subject set. Added ahead of their tables so transition() is generic across
  // every entity; the corresponding domain tables land in later milestones (#8/#9/#10/etc.).
  taskTemplate     @map("task_template")
  scheduledTask    @map("scheduled_task")
  taskOccurrence   @map("task_occurrence")
  taskCompletion   @map("task_completion")
  evidence         @map("evidence")
  exception        @map("exception")
  correctiveAction @map("corrective_action")
  exportJob        @map("export_job")
  notification     @map("notification")

  @@map("activity_subject_type")
}

// ---- Global identity (NOT tenant-scoped, global by design) ----------------------

model User {
  id            String    @id @default(dbgenerated("uuidv7()")) @db.Uuid
  email         String    @unique
  emailVerified Boolean   @default(false) @map("email_verified")
  name          String?
  locale        String?
  createdAt     DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)

  memberships     Membership[]
  invitationsSent Invitation[] @relation("InvitedBy")
  staffPins       StaffPin[]
  attachmentsUploaded Attachment[] @relation("AttachmentUploadedBy")

  scheduledTasks  ScheduledTask[]  @relation("ScheduledTaskAssignee")
  taskOccurrences TaskOccurrence[] @relation("TaskOccurrenceAssignee")
  taskCompletions TaskCompletion[] @relation("TaskCompletionCompletedBy")

  exceptionsOpened            Exception[]        @relation("ExceptionOpenedBy")
  correctiveActionsAssigned   CorrectiveAction[] @relation("CorrectiveActionAssignee")
  correctiveActionsCompleted  CorrectiveAction[] @relation("CorrectiveActionCompletedBy")
  correctiveActionsVerified   CorrectiveAction[] @relation("CorrectiveActionVerifiedBy")

  @@map("users")
}

// ---- Tenant root ----------------------------------------------------------------

model Organization {
  id              String    @id @default(dbgenerated("uuidv7()")) @db.Uuid
  name            String
  slug            String    @unique
  defaultLocale   String    @default("de") @map("default_locale")
  defaultTimezone String    @default("Europe/Berlin") @map("default_timezone")
  retentionDays   Int       @default(1095) @map("retention_days") // D5/F8: 3y default, per-org configurable
  legalHold       Boolean   @default(false) @map("legal_hold")
  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt       DateTime? @map("deleted_at") @db.Timestamptz(6)

  memberships     Membership[]
  invitations     Invitation[]
  staffPins       StaffPin[]
  properties      Property[]
  outlets         Outlet[]
  activityLogs    ActivityLog[]
  taskTemplates   TaskTemplate[]
  scheduledTasks  ScheduledTask[]
  taskOccurrences TaskOccurrence[]
  taskCompletions TaskCompletion[]
  evidence        Evidence[]
  attachments     Attachment[]
  exceptions       Exception[]
  correctiveActions CorrectiveAction[]

  @@map("organizations")
}

// ---- Tenant-scoped tables (organization_id on every one) ------------------------

model Membership {
  id             String    @id @default(dbgenerated("uuidv7()")) @db.Uuid
  organizationId String    @map("organization_id") @db.Uuid
  userId         String    @map("user_id") @db.Uuid
  role           OrgRole
  propertyScope  String[]  @map("property_scope") @db.Uuid // empty = whole org; else limited to these property ids
  status         String    @default("active")
  createdAt      DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt      DateTime? @map("deleted_at") @db.Timestamptz(6)

  organization Organization @relation(fields: [organizationId], references: [id])
  user         User         @relation(fields: [userId], references: [id])

  @@unique([organizationId, userId])
  @@index([userId])
  @@index([organizationId, role])
  @@map("memberships")
}

model Invitation {
  id             String           @id @default(dbgenerated("uuidv7()")) @db.Uuid
  organizationId String           @map("organization_id") @db.Uuid
  email          String
  role           OrgRole
  propertyScope  String[]         @map("property_scope") @db.Uuid
  token          String           @unique
  status         InvitationStatus @default(pending)
  invitedById    String           @map("invited_by") @db.Uuid
  expiresAt      DateTime         @map("expires_at") @db.Timestamptz(6)
  acceptedAt     DateTime?        @map("accepted_at") @db.Timestamptz(6)
  createdAt      DateTime         @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime         @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt      DateTime?        @map("deleted_at") @db.Timestamptz(6)

  organization Organization @relation(fields: [organizationId], references: [id])
  invitedBy    User         @relation("InvitedBy", fields: [invitedById], references: [id])

  @@index([organizationId, status])
  @@index([organizationId, email])
  @@map("invitations")
}

model Property {
  id             String    @id @default(dbgenerated("uuidv7()")) @db.Uuid
  organizationId String    @map("organization_id") @db.Uuid
  name           String
  timezone       String // IANA — source of truth for occurrence wall-clock (later milestones)
  countryCode    String    @map("country_code") @db.Char(2)
  addressJson    Json?     @map("address_json")
  createdAt      DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt      DateTime? @map("deleted_at") @db.Timestamptz(6)

  organization    Organization     @relation(fields: [organizationId], references: [id])
  outlets         Outlet[]
  scheduledTasks  ScheduledTask[]
  taskOccurrences TaskOccurrence[]
  exceptions      Exception[]

  @@unique([organizationId, name])
  @@index([organizationId, deletedAt])
  @@map("properties")
}

model Outlet {
  id             String    @id @default(dbgenerated("uuidv7()")) @db.Uuid
  organizationId String    @map("organization_id") @db.Uuid
  propertyId     String    @map("property_id") @db.Uuid
  name           String
  createdAt      DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt      DateTime? @map("deleted_at") @db.Timestamptz(6)

  organization    Organization     @relation(fields: [organizationId], references: [id])
  property        Property         @relation(fields: [propertyId], references: [id])
  scheduledTasks  ScheduledTask[]
  taskOccurrences TaskOccurrence[]
  exceptions      Exception[]

  @@unique([propertyId, name])
  @@index([organizationId, propertyId, deletedAt])
  @@map("outlets")
}

// Append-only audit log. No updated_at / deleted_at. UPDATE/DELETE rejected by a
// database trigger (see the rls_immutability migration). `seq` is a global ordering
// sequence (F5 keyset). The tamper-evident hash chain (F6, #13) adds a per-org DENSE
// chain_seq + prev_hash/row_hash, all computed by the SECURITY DEFINER log_activity()
// function (prisma/superuser/) so application code cannot forge them.
model ActivityLog {
  id             String              @id @default(dbgenerated("uuidv7()")) @db.Uuid
  organizationId String              @map("organization_id") @db.Uuid
  seq            BigInt              @default(autoincrement())
  subjectType    ActivitySubjectType @map("subject_type")
  subjectId      String              @map("subject_id") @db.Uuid
  action         String
  actorUserId    String?             @map("actor_user_id") @db.Uuid
  actorLabel     String?             @map("actor_label")
  beforeJson     Json?               @map("before_json")
  afterJson      Json?               @map("after_json")
  reason         String?
  createdAt      DateTime            @default(now()) @map("created_at") @db.Timestamptz(6)
  /// F6 hash chain (#13), all set by log_activity(): per-org dense position + linked SHA-256 hashes.
  chainSeq       BigInt?             @map("chain_seq")
  prevHash       String?             @map("prev_hash")
  rowHash        String?             @map("row_hash")

  organization Organization @relation(fields: [organizationId], references: [id])

  @@index([organizationId, subjectType, subjectId, seq])
  @@index([organizationId, createdAt])
  // Org-wide timeline seek (F5 keyset by seq): the per-subject index above cannot serve
  // `WHERE organization_id = ? ORDER BY seq DESC` without a sort. (#55)
  @@index([organizationId, seq])
  @@map("activity_log")
}

// ---- Occurrence domain (#8; §8.11-§8.13) ----------------------------------------
// Mutable tenant-scoped tables (soft-delete via deleted_at). RLS + FORCE + tenant_isolation
// policy applied via raw SQL in the occurrence_domain migration. NOT append-only (no reject
// trigger) — unlike activity_log / task_completions. template_library (source_library_id) is
// a later-milestone table, so source_library_id is a plain nullable UUID column with no FK yet.

model TaskTemplate {
  id               String        @id @default(dbgenerated("uuidv7()")) @db.Uuid
  organizationId   String        @map("organization_id") @db.Uuid
  sourceLibraryId  String?       @map("source_library_id") @db.Uuid
  checkType        CheckType     @map("check_type")
  title            String
  titleI18n        Json?         @map("title_i18n")
  instructions     String?
  requiredEvidence EvidenceType[] @default([]) @map("required_evidence")
  targetConfigJson Json?         @map("target_config_json")
  isActive         Boolean       @default(true) @map("is_active")
  createdAt        DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime      @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt        DateTime?     @map("deleted_at") @db.Timestamptz(6)

  organization    Organization     @relation(fields: [organizationId], references: [id])
  scheduledTasks  ScheduledTask[]
  taskOccurrences TaskOccurrence[]

  @@index([organizationId, isActive, deletedAt])
  @@index([organizationId, checkType])
  @@map("task_templates")
}

model ScheduledTask {
  id             String         @id @default(dbgenerated("uuidv7()")) @db.Uuid
  organizationId String         @map("organization_id") @db.Uuid
  propertyId     String         @map("property_id") @db.Uuid
  outletId       String         @map("outlet_id") @db.Uuid
  taskTemplateId String         @map("task_template_id") @db.Uuid
  recurrenceJson Json           @map("recurrence_json")
  recurrenceFreq RecurrenceFreq @map("recurrence_freq")
  timeOfDay      DateTime       @map("time_of_day") @db.Time(6)
  timezone       String
  assigneeRole   OrgRole?       @map("assignee_role")
  assigneeUserId String?        @map("assignee_user_id") @db.Uuid
  graceMinutes   Int            @default(15) @map("grace_minutes")
  startsOn       DateTime       @map("starts_on") @db.Date
  endsOn         DateTime?      @map("ends_on") @db.Date
  isActive       Boolean        @default(true) @map("is_active")
  createdAt      DateTime       @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime       @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt      DateTime?      @map("deleted_at") @db.Timestamptz(6)

  organization    Organization     @relation(fields: [organizationId], references: [id])
  property        Property         @relation(fields: [propertyId], references: [id])
  outlet          Outlet           @relation(fields: [outletId], references: [id])
  taskTemplate    TaskTemplate     @relation(fields: [taskTemplateId], references: [id])
  assigneeUser    User?            @relation("ScheduledTaskAssignee", fields: [assigneeUserId], references: [id])
  taskOccurrences TaskOccurrence[]

  @@index([organizationId, isActive, deletedAt])
  @@index([organizationId, outletId, isActive])
  @@index([isActive, endsOn])
  @@map("scheduled_tasks")
}

model TaskOccurrence {
  id                  String           @id @default(dbgenerated("uuidv7()")) @db.Uuid
  organizationId      String           @map("organization_id") @db.Uuid
  propertyId          String           @map("property_id") @db.Uuid
  outletId            String           @map("outlet_id") @db.Uuid
  scheduledTaskId     String           @map("scheduled_task_id") @db.Uuid
  taskTemplateId      String           @map("task_template_id") @db.Uuid
  checkType           CheckType        @map("check_type")
  // Frozen copy of the template's threshold + required-evidence config at generation time (§8.13
  // config_snapshot invariant), so a later template edit cannot re-judge historical occurrences.
  configSnapshot      Json?            @map("config_snapshot")
  occurrenceLocalDate DateTime         @map("occurrence_local_date") @db.Date
  dueAt               DateTime         @map("due_at") @db.Timestamptz(6)
  timezone            String
  status              OccurrenceStatus @default(pending)
  // Exactly one of (assigneeRole, assigneeUserId) is non-null — enforced by the
  // task_occurrences_assignee_xor CHECK in migration 20260706150000_occurrence_assignee_xor
  // (Prisma cannot express a XOR CHECK; mirrors scheduled_tasks). #98.
  assigneeRole        OrgRole?         @map("assignee_role")
  assigneeUserId      String?          @map("assignee_user_id") @db.Uuid
  completedAt         DateTime?        @map("completed_at") @db.Timestamptz(6)
  createdAt           DateTime         @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt           DateTime         @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt           DateTime?        @map("deleted_at") @db.Timestamptz(6)

  organization  Organization  @relation(fields: [organizationId], references: [id])
  property      Property      @relation(fields: [propertyId], references: [id])
  outlet        Outlet        @relation(fields: [outletId], references: [id])
  scheduledTask ScheduledTask @relation(fields: [scheduledTaskId], references: [id])
  taskTemplate  TaskTemplate  @relation(fields: [taskTemplateId], references: [id])
  assigneeUser  User?         @relation("TaskOccurrenceAssignee", fields: [assigneeUserId], references: [id])
  completions   TaskCompletion[]
  exceptions    Exception[]

  @@unique([scheduledTaskId, occurrenceLocalDate])
  @@index([organizationId, propertyId, outletId, occurrenceLocalDate, status])
  // The overdue-sweep index is PARTIAL — (status, due_at) WHERE status IN ('pending','due') —
  // and lives only in the occurrence_domain migration (Prisma cannot express a partial index).
  // Do NOT add a full @@index([status, dueAt]) here: it would be a second, unbounded index and
  // would make `prisma migrate diff` report drift against the intentional partial index.
  @@index([organizationId, assigneeUserId, occurrenceLocalDate])
  @@index([organizationId, status, occurrenceLocalDate])
  @@map("task_occurrences")
}

// ---- Compliance records (#53; §8.14 task_completions, §8.15 evidence) -----------
// IMMUTABLE / append-only: NO updated_at, NO deleted_at. UPDATE/DELETE/TRUNCATE are rejected by
// DB triggers (see the completions_evidence migration), mirroring activity_log. Corrections do
// NOT mutate a row — they insert a new version (version+1, supersedes_id) via a SECURITY DEFINER
// path deferred to M4 #17. F3: recorded_at is server-authoritative (DB DEFAULT now()), never set
// by the client; client_reported_at is the device's self-reported time, advisory only.

model TaskCompletion {
  id                      String           @id @default(dbgenerated("uuidv7()")) @db.Uuid
  organizationId          String           @map("organization_id") @db.Uuid
  taskOccurrenceId        String           @map("task_occurrence_id") @db.Uuid
  /// 1-based, monotonic per occurrence. DB CHECK enforces version >= 1 (Prisma can't express it).
  version                 Int              @default(1)
  isCurrent               Boolean          @default(true) @map("is_current")
  /// Prior version this row corrects. DB CHECK enforces v>=2 carries edit_reason + supersedes_id.
  supersedesId            String?          @map("supersedes_id") @db.Uuid
  clientSubmissionId      String           @map("client_submission_id") @db.Uuid
  result                  CompletionResult
  enteredValuesJson       Json             @default("{}") @map("entered_values_json")
  measuredNumeric         Decimal?         @map("measured_numeric") @db.Decimal
  completedBy             String           @map("completed_by") @db.Uuid
  /// Shared-tablet actor identity (D8). Domain: 'session' | 'pin' | 'initials'. Prisma cannot
  /// express the CHECK, so it is enforced by task_completions_actor_confirmation_method_check in
  /// migration 20260703170000_actor_method_check (mirrored by assertValidConfirmationMethod).
  actorConfirmationMethod String           @default("session") @map("actor_confirmation_method")
  /// F3 compliance timestamp. Server-authoritative: a BEFORE INSERT trigger unconditionally overwrites
  /// any supplied value with clock_timestamp() (real wall-clock, not tx-start now()), so the client can
  /// never drive it and every insert gets a distinct instant (the @default is belt-and-braces).
  recordedAt              DateTime         @default(now()) @map("recorded_at") @db.Timestamptz(6)
  clientReportedAt        DateTime?        @map("client_reported_at") @db.Timestamptz(6)
  deviceMetaJson          Json?            @map("device_meta_json")
  /// Why this correction was made. DB CHECK enforces v>=2 carries it (with supersedes_id).
  editReason              String?          @map("edit_reason")
  createdAt               DateTime         @default(now()) @map("created_at") @db.Timestamptz(6)

  organization   Organization     @relation(fields: [organizationId], references: [id])
  taskOccurrence TaskOccurrence   @relation(fields: [taskOccurrenceId], references: [id])
  supersedes     TaskCompletion?  @relation("TaskCompletionVersion", fields: [supersedesId], references: [id])
  supersededBy   TaskCompletion[] @relation("TaskCompletionVersion")
  completedByUser User            @relation("TaskCompletionCompletedBy", fields: [completedBy], references: [id])
  evidence       Evidence[]
  exceptions     Exception[]

  @@unique([taskOccurrenceId, version])
  @@unique([organizationId, clientSubmissionId])
  @@index([organizationId, taskOccurrenceId, version])
  @@index([organizationId, result, recordedAt])
  @@map("task_completions")
}

model Evidence {
  id               String       @id @default(dbgenerated("uuidv7()")) @db.Uuid
  organizationId   String       @map("organization_id") @db.Uuid
  taskCompletionId String       @map("task_completion_id") @db.Uuid
  type             EvidenceType
  valueText        String?      @map("value_text")
  valueNumeric     Decimal?     @map("value_numeric") @db.Decimal
  valueBool        Boolean?     @map("value_bool")
  // Binary evidence (photo/file/drawn-signature) points at an R2 object via attachments (§8.16, #104).
  // The FK is single-column here; a tenant-qualified composite (organization_id, attachment_id) FK +
  // the D4 binary-requires-attachment / value-shape CHECKs live ONLY in the 20260707120000_attachments
  // migration (Prisma can't express them) - expected `migrate dev` drift, same as #94/#95.
  attachmentId     String?      @map("attachment_id") @db.Uuid
  capturedAt       DateTime     @default(now()) @map("captured_at") @db.Timestamptz(6)
  createdAt        DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)

  organization   Organization   @relation(fields: [organizationId], references: [id])
  taskCompletion TaskCompletion @relation(fields: [taskCompletionId], references: [id])
  attachment     Attachment?    @relation(fields: [attachmentId], references: [id])

  @@index([organizationId, taskCompletionId])
  @@index([organizationId, type])
  @@map("evidence")
}

// ---- Attachments (#104; §8.16 - R2 object metadata) -----------------------------
// MUTABLE (soft-delete via deleted_at, has updated_at) - NOT append-only: status/byte_size/
// checksum_sha256 are written once at finalize (#106). RLS + FORCE + tenant_isolation, the
// UNIQUE(r2_bucket, r2_key), the composite tenant FKs, and the status/checksum CHECKs live in the
// 20260707120000_attachments migration. Files live in Cloudflare R2 (EU), never in Postgres and never
// served directly from the app (presigned GET only, #107).
model Attachment {
  id             String    @id @default(dbgenerated("uuidv7()")) @db.Uuid
  organizationId String    @map("organization_id") @db.Uuid
  r2Bucket       String    @map("r2_bucket")
  r2Key          String    @map("r2_key")
  contentType    String    @map("content_type")
  /// Set on finalize (#106). Null while pending.
  byteSize       BigInt?   @map("byte_size")
  /// F6 integrity checksum. Null until finalize, then required (DB CHECK: uploaded => checksum + size).
  checksumSha256 String?   @map("checksum_sha256")
  /// 'pending' -> 'uploaded' (finalize). DB CHECK constrains the domain (Prisma can't express it).
  status         String    @default("pending")
  /// Photo capture time preserved from EXIF at finalize (#106) after EXIF/GPS is stripped. Null when
  /// not a photo or no DateTimeOriginal tag was present.
  capturedAt     DateTime? @map("captured_at") @db.Timestamptz(6)
  uploadedBy     String?   @map("uploaded_by") @db.Uuid
  createdAt      DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt      DateTime? @map("deleted_at") @db.Timestamptz(6)

  organization   Organization @relation(fields: [organizationId], references: [id])
  uploadedByUser User?        @relation("AttachmentUploadedBy", fields: [uploadedBy], references: [id])
  evidence       Evidence[]

  @@unique([r2Bucket, r2Key])
  @@index([organizationId, status])
  @@map("attachments")
}

// ---- Exceptions + corrective actions (#9; §8.17 exceptions, §8.18 corrective_actions) -----------
// Mutable tenant-scoped tables (soft-delete via deleted_at, have updated_at). RLS + FORCE +
// tenant_isolation applied via raw SQL in the exceptions_corrective migration. NOT append-only
// (no reject trigger). The D2 state machines (§7.2/§7.3) live in src/lib/exceptions.ts and route
// every status change through the F4 transition() choke point.

model Exception {
  id               String          @id @default(dbgenerated("uuidv7()")) @db.Uuid
  organizationId   String          @map("organization_id") @db.Uuid
  propertyId       String          @map("property_id") @db.Uuid
  outletId         String          @map("outlet_id") @db.Uuid
  taskOccurrenceId String          @map("task_occurrence_id") @db.Uuid
  taskCompletionId String?         @map("task_completion_id") @db.Uuid
  status           ExceptionStatus @default(open)
  severity         String          @default("normal")
  title            String
  detail           String?
  openedBy         String?         @map("opened_by") @db.Uuid
  openedAt         DateTime        @default(now()) @map("opened_at") @db.Timestamptz(6)
  resolvedAt       DateTime?       @map("resolved_at") @db.Timestamptz(6)
  createdAt        DateTime        @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime        @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt        DateTime?       @map("deleted_at") @db.Timestamptz(6)

  organization   Organization    @relation(fields: [organizationId], references: [id])
  property       Property        @relation(fields: [propertyId], references: [id])
  outlet         Outlet          @relation(fields: [outletId], references: [id])
  taskOccurrence TaskOccurrence  @relation(fields: [taskOccurrenceId], references: [id])
  taskCompletion TaskCompletion? @relation(fields: [taskCompletionId], references: [id])
  openedByUser   User?           @relation("ExceptionOpenedBy", fields: [openedBy], references: [id])
  correctiveActions CorrectiveAction[]

  @@index([organizationId, status, openedAt])
  @@index([organizationId, outletId, status])
  @@index([organizationId, taskOccurrenceId])
  @@map("exceptions")
}

model CorrectiveAction {
  id             String           @id @default(dbgenerated("uuidv7()")) @db.Uuid
  organizationId String           @map("organization_id") @db.Uuid
  exceptionId    String           @map("exception_id") @db.Uuid
  status         CorrectiveStatus @default(open)
  description    String
  assigneeUserId String?          @map("assignee_user_id") @db.Uuid
  assigneeRole   OrgRole?         @map("assignee_role")
  dueAt          DateTime?        @map("due_at") @db.Timestamptz(6)
  completedBy    String?          @map("completed_by") @db.Uuid
  completedAt    DateTime?        @map("completed_at") @db.Timestamptz(6)
  verifiedBy     String?          @map("verified_by") @db.Uuid
  verifiedAt     DateTime?        @map("verified_at") @db.Timestamptz(6)
  // F2 (#96): client-supplied idempotency key for the markDone completion. An offline-queue retry
  // that re-sends `done` with the SAME id is recognized as an idempotent replay (returns the row,
  // no second audit / no re-cascade); NULL means no key was supplied (a done→done retry then still
  // throws the illegal transition — a genuine conflict, not a known replay).
  completionSubmissionId String?   @map("completion_submission_id") @db.Uuid
  createdAt      DateTime         @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime         @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt      DateTime?        @map("deleted_at") @db.Timestamptz(6)

  organization  Organization @relation(fields: [organizationId], references: [id])
  exception     Exception    @relation(fields: [exceptionId], references: [id])
  assigneeUser  User?        @relation("CorrectiveActionAssignee", fields: [assigneeUserId], references: [id])
  completedByUser User?      @relation("CorrectiveActionCompletedBy", fields: [completedBy], references: [id])
  verifiedByUser  User?      @relation("CorrectiveActionVerifiedBy", fields: [verifiedBy], references: [id])

  @@index([organizationId, status, dueAt])
  @@index([organizationId, exceptionId])
  @@index([organizationId, assigneeUserId, status])
  @@map("corrective_actions")
}

// ---- Shared-tablet PIN (#69; D8 §8.8) -------------------------------------------
// MUTABLE, org-scoped table — one PIN per member per org, set/reset/relocked in place.
// NOT append-only (has updated_at, no reject trigger). The PIN is stored ONLY as a scrypt
// hash (pin_hash) — never plaintext, never logged. Issuance/verification/lockout logic lives
// in src/lib/staff-pin.ts. RLS + FORCE + tenant_isolation applied via raw SQL in the staff_pins
// migration.

model StaffPin {
  id             String    @id @default(dbgenerated("uuidv7()")) @db.Uuid
  organizationId String    @map("organization_id") @db.Uuid
  userId         String    @map("user_id") @db.Uuid
  pinHash        String    @map("pin_hash")
  pinSetAt       DateTime  @default(now()) @map("pin_set_at") @db.Timestamptz(6)
  failedAttempts Int       @default(0) @map("failed_attempts")
  lockedUntil    DateTime? @map("locked_until") @db.Timestamptz(6)
  createdAt      DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)

  organization Organization @relation(fields: [organizationId], references: [id])
  user         User         @relation(fields: [userId], references: [id])

  @@unique([organizationId, userId], map: "staff_pins_org_user_key")
  @@index([organizationId, userId], map: "staff_pins_org_user_idx")
  @@map("staff_pins")
}
